/* ===================== USER FUNCTIONS ===================== */

void dot(void)
{
  HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_SET);
  HAL_Delay(200);
  HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_RESET);
  HAL_Delay(200);
}

void dash(void)
{
  HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_SET);
  HAL_Delay(600);
  HAL_GPIO_WritePin(GPIOA, GPIO_PIN_5, GPIO_PIN_RESET);
  HAL_Delay(200);
}

void SOS(void)
{
  // S = ...
  dot();
  dot();
  dot();
  HAL_Delay(600);

  // O = ---
  dash();
  dash();
  dash();
  HAL_Delay(600);

  // S = ...
  dot();
  dot();
  dot();
}

/* Interrupt Callback */
void HAL_GPIO_EXTI_Callback(uint16_t GPIO_Pin)
{
  if (GPIO_Pin == GPIO_PIN_13)  // Blue button PC13
  {
    SOS();
  }
}

/* ===================== MAIN ===================== */

int main(void)
{
  HAL_Init();
  SystemClock_Config();
  MX_GPIO_Init();
  MX_USART2_UART_Init();

  while (1)
  {
    // Do nothing, wait for button interrupt
  }
}

