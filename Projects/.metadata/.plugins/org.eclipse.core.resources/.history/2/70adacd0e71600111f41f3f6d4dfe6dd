/* ================= DHT FUNCTIONS ================= */

void DHT_Start(void)
{
  Set_Pin_Output();
  HAL_GPIO_WritePin(GPIOA, GPIO_PIN_1, GPIO_PIN_RESET);
  HAL_Delay(18);
  HAL_GPIO_WritePin(GPIOA, GPIO_PIN_1, GPIO_PIN_SET);
  delay_us(28);
  Set_Pin_Input();
}

uint8_t DHT_CheckResponse(void)
{
  uint8_t response = 0;
  delay_us(38);

  if (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_1) == GPIO_PIN_RESET)
  {
    delay_us(80);
    if (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_1) == GPIO_PIN_SET)
      response = 1;
  }

  while (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_1) == GPIO_PIN_SET);
  return response;
}

uint8_t DHT_Read(void)
{
  uint8_t value = 0;

  for (int i = 0; i < 8; i++)
  {
    while (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_1) == GPIO_PIN_RESET);

    delay_us(30);   // ← CHANGED FROM 40 TO 30

    if (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_1) == GPIO_PIN_SET)
      value |= (1 << (7 - i));

    while (HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_1) == GPIO_PIN_SET);
  }

  return value;
}

/* ================= MAIN ================= */

int main(void)
{
  HAL_Init();
  SystemClock_Config();
  MX_GPIO_Init();
  MX_USART2_UART_Init();

  DWT_Init();

  uint8_t Rh1, Rh2, T1, T2, SUM;   // ← MOVE THIS HERE (before while)

  while (1)
  {
      DHT_Start();

      if (DHT_CheckResponse())
      {
          Rh1 = DHT_Read();
          Rh2 = DHT_Read();
          T1  = DHT_Read();
          T2  = DHT_Read();
          SUM = DHT_Read();
          printf("H1=%d H2=%d T1=%d T2=%d SUM=%d CALC=%d\r\n",
                  Rh1, Rh2, T1, T2, SUM,
                  (Rh1 + Rh2 + T1 + T2));

          if (SUM == (Rh1 + Rh2 + T1 + T2))
          {
              // For DHT11 (no decimals used)
              printf("Temperature: %d C  Humidity: %d %%\r\n", T1, Rh1);
          }
          else
          {
              printf("Checksum Error\r\n");
          }
      }
      else
      {
          printf("No Response\r\n");
      }

      HAL_Delay(2000);
  }
}
